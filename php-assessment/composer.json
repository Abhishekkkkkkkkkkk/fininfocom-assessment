{
    "name": "fininfocom/php-assessment",
    "type": "project",
    "description": "Fullstack Developer Assessment - PHP CodeIgniter 4",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        }
    },
    "config": {
        "allow-plugins": {
            "codeigniter4/composer-installer": true
        }
    }
}
